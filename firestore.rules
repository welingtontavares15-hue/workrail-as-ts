rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil;
    }

    // Aceita tanto o nome canônico quanto aliases legados
    function isSuperAdmin() {
      return getUserProfile() == 'super_admin';
    }

    function isSupervisorASTS() {
      let p = getUserProfile();
      return p == 'supervisor_asts' || p == 'gestor';
    }

    function isAdmVendas() {
      let p = getUserProfile();
      return p == 'adm_vendas' || p == 'adm';
    }

    // Perfis que NÃO podem ser atribuídos pelo próprio usuário na criação
    // Impede escalada de privilégio: cliente envia perfil=super_admin no primeiro write
    function isPerfilPrivilegiado(perfil) {
      return perfil in ['super_admin', 'adm_vendas', 'adm', 'supervisor_asts', 'gestor'];
    }

    function canViewSolicitacao() {
      let doc = resource.data;
      let perfil = getUserProfile();
      let uid = request.auth.uid;
      // Acesso seguro via get() — dadosAdm pode não existir em etapas iniciais (solicitacao/gestor).
      // Sem esse cuidado, o null dereference derruba a avaliação e nega acesso a todos os perfis.
      let enc  = doc.get(['dadosAdm', 'encaminhadoFornecedor'], '');
      let forn = doc.get(['dadosAdm', 'fornecedor'], '');
      let fornecedorEBST   = enc == 'EBST'          || forn == 'EBST';
      let fornecedorHobart = enc == 'Hobart Brasil'  || forn == 'Hobart Brasil';
      return isSuperAdmin()
          || isSupervisorASTS()
          || isAdmVendas()
          || (perfil == 'vendas' && doc.criadoPorUid == uid)
          || (perfil == 'fornecedor_ebst' && fornecedorEBST)
          || (perfil == 'fornecedor_hobart' && fornecedorHobart);
    }

    function canEditEtapa(etapa) {
      // etapa vem do campo etapaAtual nos documentos Firestore
      // FLOW = ['solicitacao','gestor','adm','fornecedor','logistica','instalacao','relatorio','concluido']
      return isSuperAdmin()
          || (etapa == 'solicitacao' && getUserProfile() == 'vendas')
          || ((etapa == 'gestor' || etapa == 'supervisor') && isSupervisorASTS())
          || ((etapa == 'adm' || etapa == 'adm_vendas') && isAdmVendas())
          // Fornecedor edita sua etapa com base no perfil — acesso seguro via get()
          || (etapa == 'fornecedor' && getUserProfile() == 'fornecedor_ebst'
              && (resource.data.get(['dadosAdm','encaminhadoFornecedor'],'') == 'EBST'
                  || resource.data.get(['dadosAdm','fornecedor'],'') == 'EBST'))
          || (etapa == 'fornecedor' && getUserProfile() == 'fornecedor_hobart'
              && (resource.data.get(['dadosAdm','encaminhadoFornecedor'],'') == 'Hobart Brasil'
                  || resource.data.get(['dadosAdm','fornecedor'],'') == 'Hobart Brasil'))
          || ((etapa == 'logistica') && isAdmVendas())
          || ((etapa == 'instalacao' || etapa == 'data_instalacao') && isSupervisorASTS())
          || ((etapa == 'relatorio' || etapa == 'relatorio_final') && isSupervisorASTS());
    }

    // Valida que a transição de etapa é uma progressão legítima no fluxo.
    // Evita que um cliente mal-intencionado pule etapas ou retroceda arbitrariamente.
    function isValidTransition(from, to) {
      return from == to  // atualização sem mudança de etapa (sempre válida)
          || (from == 'solicitacao' && to in ['gestor'])
          || (from == 'gestor'      && to in ['adm', 'solicitacao'])
          || (from == 'adm'         && to in ['fornecedor', 'gestor'])
          || (from == 'fornecedor'  && to in ['logistica'])
          || (from == 'logistica'   && to in ['instalacao'])
          || (from == 'instalacao'  && to in ['relatorio'])
          || (from == 'relatorio'   && to in ['concluido'])
          || (from == 'concluido'   && to == 'concluido');
    }

    match /usuarios/{userId} {
      allow read: if request.auth.uid == userId || isSuperAdmin();
      // Bootstrap: usuário autenticado pode criar o próprio documento se ainda não existir.
      // SEGURANÇA: não é permitido atribuir perfis privilegiados (adm, supervisor, super_admin).
      // Isso impede escalada de privilégio via primeiro write do cliente.
      allow create: if isSuperAdmin()
                    || (request.auth.uid == userId
                        && !exists(/databases/$(database)/documents/usuarios/$(userId))
                        && !isPerfilPrivilegiado(request.resource.data.perfil));
      allow update, delete: if isSuperAdmin();
    }

    match /fornecedores/{docId} {
      allow read: if request.auth.uid != null;
      allow create, update, delete: if isSuperAdmin() || isAdmVendas();
    }

    match /modelos_maquinas/{docId} {
      allow read: if request.auth.uid != null;
      allow create, update, delete: if isSuperAdmin() || isAdmVendas();
    }

    match /solicitacoes/{solicitacaoId} {
      allow read: if canViewSolicitacao();
      // Criar: qualquer usuário autenticado com perfil válido (vendas OU super_admin)
      // criadoPorUid deve ser o próprio UID do usuário logado
      // etapaAtual deve iniciar em 'solicitacao' (regra de integridade do fluxo)
      allow create: if request.auth.uid != null
                    && request.resource.data.criadoPorUid == request.auth.uid
                    && request.resource.data.etapaAtual == 'solicitacao'
                    && (isSuperAdmin() || getUserProfile() == 'vendas');
      // Atualizar: deve poder ver, ter permissão de editar a etapa atual,
      // não alterar protocolo nem criadoPorUid, e só avançar/manter a etapa
      // em transições legítimas do fluxo.
      allow update: if canViewSolicitacao()
                    && canEditEtapa(resource.data.etapaAtual)
                    && request.resource.data.protocolo == resource.data.protocolo
                    && request.resource.data.criadoPorUid == resource.data.criadoPorUid
                    && isValidTransition(resource.data.etapaAtual, request.resource.data.etapaAtual);
      allow delete: if isSuperAdmin();

      match /historico/{eventoId} {
        allow read: if canViewSolicitacao();
        allow create: if canViewSolicitacao()
                      && request.resource.data.executadoPorUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /contadores/{docId} {
      allow read: if request.auth.uid != null;
      // Qualquer usuário autenticado pode incrementar contadores (geração de número WR)
      allow write: if request.auth.uid != null;
    }

    // ── Base de máquinas importadas via Excel ──────────────
    match /maquinas/{serialId} {
      // super_admin, adm_vendas, adm, supervisor_asts, gestor: leem tudo
      // fornecedor_ebst: lê apenas máquinas onde fornecedor == 'EBST'
      // fornecedor_hobart: lê apenas máquinas onde fornecedor == 'Hobart Brasil'
      allow read: if isSuperAdmin()
                  || isSupervisorASTS()
                  || isAdmVendas()
                  || (getUserProfile() == 'fornecedor_ebst'   && resource.data.fornecedor == 'EBST')
                  || (getUserProfile() == 'fornecedor_hobart' && resource.data.fornecedor == 'Hobart Brasil');
      allow write, delete: if request.auth.uid != null
                           && (isSuperAdmin() || isAdmVendas());
    }

    match /username_lookup/{username} {
      // Leitura pública mantida para que o login por username funcione antes da autenticação.
      allow read: if true;
      // Criar: apenas o próprio usuário pode registrar seu username,
      // e o UID registrado deve corresponder ao seu UID logado.
      // Isso impede que um usuário crie ou sequestre o mapeamento de outro.
      allow create: if request.auth.uid != null
                    && request.resource.data.uid == request.auth.uid;
      // Atualizar ou excluir: apenas super_admin
      // (impede sabotagem de mapeamento username → email por usuário comum)
      allow update, delete: if isSuperAdmin();
    }

    match /produtos/{docId} {
      allow read: if request.auth.uid != null;
      allow create, update, delete: if isSuperAdmin() || isAdmVendas();
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
