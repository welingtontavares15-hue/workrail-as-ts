rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Nota de segurança ──────────────────────────────────────────────
    // firestore.get() em Storage Rules requer que ambos os serviços
    // estejam na MESMA região. Este projeto tem Firestore em
    // southamerica-east1 e Storage em us-central1 — chamadas cross-region
    // falham silenciosamente com storage/unauthorized.
    //
    // Camadas de segurança aplicadas:
    //   1. Autenticação Firebase obrigatória
    //   2. Path estruturado: solicitacoes/{id}/{pasta}/{arquivo}
    //      — o ID da solicitação no path vincula ao documento Firestore
    //   3. Tipo e tamanho de arquivo validados por pasta
    //   4. Firestore Rules (southamerica-east1) controlam quem pode
    //      criar/atualizar solicitações — linha de defesa primária
    // ──────────────────────────────────────────────────────────────────

    function isAuth()  { return request.auth != null; }
    function maxMB(n)  { return request.resource.size <= n * 1024 * 1024; }
    function isPdf()   { return request.resource.contentType == 'application/pdf'; }
    function isWord()  {
      return request.resource.contentType in [
        'application/msword',
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
      ];
    }
    function isExcel() {
      return request.resource.contentType in [
        'application/vnd.ms-excel',
        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
      ];
    }
    function isImage() { return request.resource.contentType.matches('image/.*'); }

    // Contrato — PDF ou Word, máx 20 MB
    match /solicitacoes/{solicitacaoId}/contratos/{filename} {
      allow create: if isAuth() && maxMB(20) && (isPdf() || isWord());
      allow read:   if isAuth();
      allow delete: if false;
      allow update: if false;
    }

    // Formulário de pedido — PDF, Word ou Excel, máx 20 MB
    match /solicitacoes/{solicitacaoId}/formularios/{filename} {
      allow create: if isAuth() && maxMB(20) && (isPdf() || isWord() || isExcel());
      allow read:   if isAuth();
      allow delete: if false;
      allow update: if false;
    }

    // Nota Fiscal / documentos fiscais — PDF, Word ou imagem, máx 20 MB
    match /solicitacoes/{solicitacaoId}/documentos-fiscais/{filename} {
      allow create: if isAuth() && maxMB(20) && (isPdf() || isWord() || isImage());
      allow read:   if isAuth();
      allow delete: if false;
      allow update: if false;
    }

    // Comprovante de entrega — PDF, Word ou imagem, máx 20 MB
    match /solicitacoes/{solicitacaoId}/comprovantes/{filename} {
      allow create: if isAuth() && maxMB(20) && (isPdf() || isWord() || isImage());
      allow read:   if isAuth();
      allow delete: if false;
      allow update: if false;
    }

    // Relatório de instalação — PDF, Word ou imagem, máx 20 MB
    match /solicitacoes/{solicitacaoId}/relatorios/{filename} {
      allow create: if isAuth() && maxMB(20) && (isPdf() || isWord() || isImage());
      allow read:   if isAuth();
      allow delete: if false;
      allow update: if false;
    }

    // Bloqueia qualquer outro path
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
